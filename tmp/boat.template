[core]
#@memory marked_hp: float
# disp = display onMar = on marked
#@memory disp_hp_onMar: float
#ry: disupdateUnitMemop_hp_onMar= max( self.hp, memory.disp_hp_onMar - 0.5- ((memory.marked_hp - self.hp) / 250)), marked_hp= select( int(memory.disp_hp_onMar + 20.5) == self.hp, self.hp, memory.marked_hp)
#updateUnitMemoryRate:0 
showActionsWithMixedSelectionIfOtherUnitsHaveTag:boat
autoTriggerCheckRate:every8Frames
[attack]
isMelee:true
meleeEngangementDistance:100
attackMovement:bomber
[graphics]
showEnergyBar:false
showHealthBar:false
showShieldBar:false

disableLowHpSmoke:true
disableLowHpFire:true

[hiddenAction_hpac]
autoTriggerOnEvent:created
setUnitStats:hp=1
[hiddenAction_ent]
autoTriggerOnEvent:enteredTransport
addResourcesWithLogic:红宝石=self.hp-1
alsoQueueAction:offhp
[hiddenAction_offhp]
buildSpeed:0.7s
setUnitStats:hp=1

#[hiddenAction_AI]
